{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Debug x86",
            "type": "process",
            "command": "powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy", "Bypass",
                "-File",
                "${workspaceFolder}\\.vscode\\build.ps1"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        }
    ]
}
